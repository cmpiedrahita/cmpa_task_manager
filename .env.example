# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=cmpa_user
POSTGRES_PASSWORD=cmpa_password
POSTGRES_DB=cmpa_db

# ─── pgAdmin ──────────────────────────────────────────────
PGADMIN_EMAIL=admin@cmpa.dev
PGADMIN_PASSWORD=admin123

# ─── Backend ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://cmpa_user:cmpa_password@localhost:5432/cmpa_db

JWT_SECRET=change_this_to_a_random_64_char_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_another_random_64_char_string
JWT_REFRESH_EXPIRES_IN=7d

# ─── Frontend ─────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api

# ─── IA (Hito 4) ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
