{
  "name": "cmpa-task-manager",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/backend\" \"npm run dev -w apps/frontend\"",
    "migrate": "npm run migrate -w apps/backend",
    "seed": "npm run seed -w apps/backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
